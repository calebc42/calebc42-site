/* Enhanced navigation with YoRHa styling */
.yorha-nav ul {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0 0;
    display: flex;
    position: relative;
    border-bottom: 2px solid var(--yorha-text);
}

.yorha-nav li {
    position: relative;
}

.yorha-nav li::before {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background: var(--yorha-accent);
    transition: width 0.3s ease;
}

.yorha-nav li:hover::before {
    width: 100%;
}

.yorha-nav li a {
    display: block;
    padding: 0.75em 1.5em;
    text-decoration: none;
    color: var(--yorha-text);
    background-color: transparent;
    border: 2px solid transparent;
    border-bottom: none;
    position: relative;
    top: 2px;
    transition: all 0.2s ease;
    text-transform: uppercase;
    font-weight: 400;
    letter-spacing: 0.05rem;
}

.yorha-nav li a::before {
    content: '[';
    opacity: 0;
    margin-right: 0.5rem;
    transition: opacity 0.2s ease;
}

.yorha-nav li a::after {
    content: ']';
    opacity: 0;
    margin-left: 0.5rem;
    transition: opacity 0.2s ease;
}

.yorha-nav li a:hover,
.yorha-nav li a:focus {
    background-color: var(--yorha-hover);
    color: var(--yorha-text);
    transform: translateY(-1px);
}

.yorha-nav li a:hover::before,
.yorha-nav li a:hover::after {
    opacity: 1;
}

.yorha-nav li a.active {
    background-color: var(--yorha-bg);
    border-color: var(--yorha-text);
    font-weight: 700;
}

.yorha-nav li a.active::before,
.yorha-nav li a.active::after {
    opacity: 1;
}

/* YoRHa Button Styles */
.yorha-button {
    background: transparent;
    border: 2px solid var(--yorha-text);
    color: var(--yorha-text);
    padding: 0.75rem 1.5rem;
    font-family: 'Share Tech Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
}

.yorha-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, 
        transparent, 
        rgba(77, 73, 62, 0.2), 
        transparent);
    transition: left 0.3s ease;
}

.yorha-button:hover {
    background-color: var(--yorha-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(77, 73, 62, 0.2);
}

.yorha-button:hover::before {
    left: 100%;
}

/* YoRHa Data Panel */
.yorha-panel {
    border: 2px solid var(--yorha-text);
    background: rgba(200, 194, 170, 0.1);
    padding: 1.5rem;
    margin: 1rem 0;
    position: relative;
}

.yorha-panel::before {
    content: 'DATA';
    position: absolute;
    top: -0.6rem;
    left: 1rem;
    background: var(--yorha-bg);
    padding: 0 0.5rem;
    font-size: 0.8rem;
    color: var(--yorha-accent);
    font-weight: 700;
}

/* YoRHa Terminal Text Effect */
.yorha-terminal {
    font-family: 'Share Tech Mono', monospace;
    color: var(--yorha-text);
    background: transparent;
    border: none;
    font-size: 1rem;
    letter-spacing: 0.05rem;
    line-height: 1.4;
}

.yorha-terminal::before {
    content: '> ';
    color: var(--yorha-accent);
}

/* YoRHa Loading Animation */
@keyframes loading {
    0%, 20% { opacity: 0; }
    50% { opacity: 1; }
    100% { opacity: 0; }
}

.yorha-loading::after {
    content: '...';
    animation: loading 1.5s infinite;
}

/* YoRHa Grid System */
.yorha-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin: 2rem 0;
}

.yorha-grid-item {
    border: 1px solid var(--yorha-accent);
    padding: 1rem;
    background: rgba(139, 134, 114, 0.05);
    transition: background-color 0.2s ease;
}

.yorha-grid-item:hover {
    background: rgba(139, 134, 114, 0.1);
}

/* Status indicators */
.status-indicator {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 0.5rem;
    position: relative;
}

.status-indicator.online {
    background: #5cb85c;
    box-shadow: 0 0 10px rgba(92, 184, 92, 0.5);
    animation: pulse 2s infinite;
}

.status-indicator.offline {
    background: #d9534f;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

/* Responsive design */
@media (max-width: 768px) {
    .container {
        padding: 0 2rem;
    }
    
    .yorha-nav ul {
        flex-direction: column;
    }
    
    .yorha-nav li a {
        top: 0;
        border-bottom: 1px solid var(--yorha-accent);
    }
    
    h1::before {
        display: none;
    }
}